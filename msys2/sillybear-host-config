#!/bin/bash
#
# sillybear-host-config — configure sillybear as a Windows service
#
# Must be run from an elevated (Administrator) MSYS2 shell.
# Analogous to ssh-host-config for OpenSSH on Cygwin/MSYS2.
# Based on the battle-tested install-services.sh approach.
#

set -e

SILLYBEAR_SERVICE="sillybear"
SILLYBEAR_BIN="/usr/bin/sillybear.exe"
SILLYBEAR_KEYGEN="/usr/bin/sillybearkey"
SILLYBEAR_PORT=2222

usage() {
    echo "Usage: $0 [OPTIONS]"
    echo ""
    echo "Configure sillybear SSH server as a permanent Windows service."
    echo "Must be run from an elevated (Administrator) MSYS2 shell."
    echo ""
    echo "Options:"
    echo "  -y          Answer yes to all prompts (non-interactive)"
    echo "  -p PORT     SSH port (default: 2222)"
    echo "  -u          Uninstall: stop and remove the service"
    echo "  -s          Status: show current service status"
    echo "  -h          Show this help"
    exit 0
}

check_admin() {
    if ! net session >/dev/null 2>&1; then
        echo "ERROR: This script must be run from an Administrator shell."
        echo ""
        echo "Right-click on 'MSYS2 MSYS' and select 'Run as administrator',"
        echo "then run this script again."
        exit 1
    fi
}

check_prerequisites() {
    if [ ! -x "${SILLYBEAR_BIN}" ]; then
        echo "ERROR: ${SILLYBEAR_BIN} not found. Install sillybear first:"
        echo "  pacman -S sillybear"
        exit 1
    fi

    if [ ! -x "${SILLYBEAR_KEYGEN}" ]; then
        echo "ERROR: ${SILLYBEAR_KEYGEN} not found."
        exit 1
    fi

    if ! command -v cygrunsrv >/dev/null 2>&1; then
        echo "ERROR: cygrunsrv not found. Install it first:"
        echo "  pacman -S cygrunsrv"
        exit 1
    fi
}

generate_host_key() {
    local user
    user=$(whoami)
    local sshdir="/home/${user}/.ssh"

    echo "*** Setting up SSH directory and host key..."
    mkdir -p "${sshdir}"
    chmod 700 "${sshdir}"

    local keyfile="${sshdir}/sillybear_ed25519_host_key"
    if [ -f "${keyfile}" ]; then
        echo "  Host key already exists: ${keyfile}"
    else
        echo "  Generating ed25519 host key..."
        "${SILLYBEAR_KEYGEN}" -t ed25519 -f "${keyfile}"
        chmod 600 "${keyfile}"
    fi
}

show_status() {
    if ! command -v cygrunsrv >/dev/null 2>&1; then
        echo "cygrunsrv not installed."
        exit 1
    fi

    echo "=== sillybear ==="
    cygrunsrv -Q "${SILLYBEAR_SERVICE}" 2>/dev/null || echo "  Not installed."
    echo ""
    echo "=== ssh_gateway ==="
    cygrunsrv -Q ssh_gateway 2>/dev/null || echo "  Not installed."
    exit 0
}

uninstall_service() {
    echo "*** Removing services..."
    for svc in "${SILLYBEAR_SERVICE}" ssh_gateway; do
        if cygrunsrv -Q "${svc}" >/dev/null 2>&1; then
            echo "  Stopping ${svc}..."
            cygrunsrv -E "${svc}" 2>/dev/null || true
            echo "  Removing ${svc}..."
            cygrunsrv -R "${svc}"
        else
            echo "  ${svc}: not installed."
        fi
    done
    exit 0
}

install_service() {
    local user
    user=$(whoami)
    local sshdir="/home/${user}/.ssh"

    echo "*** Installing sillybear as a Windows service..."

    # Remove old registration if any (matches install-services.sh pattern)
    cygrunsrv -R "${SILLYBEAR_SERVICE}" 2>/dev/null || true

    cygrunsrv -I "${SILLYBEAR_SERVICE}" \
        -p "${SILLYBEAR_BIN}" \
        -a "-F -u ${user} -D ${sshdir} -r ${sshdir}/sillybear_ed25519_host_key -p ${SILLYBEAR_PORT}"

    # Configure automatic restart on failure
    sc.exe failure "${SILLYBEAR_SERVICE}" reset= 60 \
        actions= restart/5000/restart/10000/restart/30000

    echo "  Service registered."
    echo ""
    echo "*** Starting service..."
    net start "${SILLYBEAR_SERVICE}"
    echo "  Service started."
}

confirm() {
    local msg="$1"
    if [ "${AUTO_YES}" = "1" ]; then
        return 0
    fi
    echo -n "${msg} (yes/no) "
    read answer
    case "${answer}" in
        [Yy]|[Yy][Ee][Ss]) return 0 ;;
        *) return 1 ;;
    esac
}

# --- Main ---

AUTO_YES=0
MODE="install"

while getopts "yp:ush" opt; do
    case "${opt}" in
        y) AUTO_YES=1 ;;
        p) SILLYBEAR_PORT="${OPTARG}" ;;
        u) MODE="uninstall" ;;
        s) MODE="status" ;;
        h) usage ;;
        *) usage ;;
    esac
done

case "${MODE}" in
    status)
        show_status
        ;;
    uninstall)
        check_admin
        check_prerequisites
        uninstall_service
        ;;
    install)
        echo ""
        echo "=== Sillybear SSH Server - Host Configuration ==="
        echo ""

        check_admin
        check_prerequisites

        echo "This script will:"
        echo "  1. Generate an ed25519 host key in ~/.ssh/"
        echo "  2. Register sillybear as a Windows service (port ${SILLYBEAR_PORT})"
        echo "  3. Configure automatic restart on failure"
        echo "  4. Start the service"
        echo ""

        if ! confirm "Do you want to continue?"; then
            echo "Aborted."
            exit 0
        fi

        echo ""
        generate_host_key
        echo ""
        install_service
        echo ""
        echo "=== Configuration complete ==="
        echo ""
        echo "The sillybear SSH server is now running on port ${SILLYBEAR_PORT}."
        echo "It will start automatically on boot and restart on failure."
        echo ""
        echo "Management commands:"
        echo "  cygrunsrv -E ${SILLYBEAR_SERVICE}    # stop"
        echo "  cygrunsrv -S ${SILLYBEAR_SERVICE}    # start"
        echo "  cygrunsrv -Q ${SILLYBEAR_SERVICE}    # status"
        echo "  $0 -u                                # uninstall all"
        ;;
esac
